{
  "name": "turtle-coach",
  "version": "1.0.0",
  "description": "거북목 자세를 감지해서 화면에 거북이를 띄우는 시스템 트레이 앱",
  "main": "main.js",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "start": "node scripts/start.js",
    "make": "electron-packager . turtle-coach --overwrite --platform=win32 --arch=x64 --out=out --icon=app-icon.ico --ignore=\"^/out$\" --ignore=\"^/dist$\" --ignore=\"^/build-icons.js$\" --ignore=\"^/scripts$\" --ignore=\"^/00_실행하기.cmd$\" --ignore=\"^/00_먼저_실행하기$\"",
    "dist": "npm run make && powershell -ExecutionPolicy Bypass -File scripts/post-build.ps1"
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-packager": "^17.1.2"
  }
}
